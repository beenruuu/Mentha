{
  "name": "mentha-api",
  "version": "1.0.0",
  "description": "AEO/GEO Intelligence Platform Backend",
  "type": "module",
  "main": "src/app.ts",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    },
    "./types": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:api": "tsx src/server.ts",
    "start:worker": "tsx src/workers/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@electric-sql/pglite": "^0.4.5",
    "@hono/node-server": "1.19.13",
    "@hono/zod-validator": "^0.7.5",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.5",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.18",
    "ioredis": "^5.4.1",
    "jszip": "^3.10.1",
    "openai": "^4.56.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "postgres": "^3.4.8",
    "tiktoken": "^1.0.15",
    "turndown": "^7.2.4",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
