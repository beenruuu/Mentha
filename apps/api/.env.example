# =============================================================================
# Mentha CLI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: PostgreSQL Database (Supabase via Drizzle ORM)
# =============================================================================
# Get your connection string from Supabase Dashboard:
# Project Settings > Database > Connection String > Transaction pooler
# IMPORTANT: Use port 6543 (Transaction pooler), NOT 5432 (direct connection)

DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# =============================================================================
# REQUIRED: OpenRouter API Key (for LLM-as-Judge, API scans, and intent extraction)
# =============================================================================
# Get from: https://openrouter.ai/keys
# Mentha routes ALL AI calls through OpenRouter - no direct provider API keys needed
OPENROUTER_API_KEY=sk-or-v1-...

# =============================================================================
# OPTIONAL: Scan Execution Mode
# =============================================================================
# browser  - Uses Camoufox browser automation (default, requires Firefox/Playwright)
# api      - Uses OpenRouter API calls instead of browser automation
# hybrid   - Runs both browser and API scans in parallel
MENTHA_SCAN_EXECUTION_MODE=browser

# =============================================================================
# OPTIONAL: Redis (for background workers)
# =============================================================================

REDIS_URL=redis://localhost:6379

# =============================================================================
# OPTIONAL: IndexNow (instant search engine notifications)
# =============================================================================
# Generate a random 32-character hex string or use:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

INDEXNOW_KEY=your-32-char-hex-key

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# =============================================================================
# REQUIRED: Authentication (Better Auth)
# =============================================================================
# Generate a secure random secret (minimum 32 characters):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

BETTER_AUTH_SECRET=your-super-secret-key-with-at-least-32-characters-here
BETTER_AUTH_URL=http://localhost:4000

# CORS - comma-separated list of allowed origins for production
# ALLOWED_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# =============================================================================
# OPTIONAL: Multi-Tenant (Enterprise)
# =============================================================================

# Default tenant ID for single-tenant mode (skip if using multi-tenant)
# DEFAULT_TENANT_ID=uuid-here
